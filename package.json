{
  "name": "ventysfy-print-agent",
  "version": "0.1.0",
  "description": "Agente local de impresion ESC/POS para Ventysfy POS con shell de escritorio",
  "author": "Ventysfy",
  "main": "src/desktop.js",
  "bin": "src/cli.js",
  "scripts": {
    "build:icon": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/generate-icon.ps1",
    "build:css": "tailwindcss -i ./src/public/app.tailwind.css -o ./src/public/app.generated.css --minify",
    "watch:css": "tailwindcss -i ./src/public/app.tailwind.css -o ./src/public/app.generated.css --watch",
    "electron:dev": "electron .",
    "start": "npm run build:css && electron .",
    "dev": "npm run build:css && concurrently -k -n css,electron -c cyan,magenta \"npm run watch:css\" \"npm run electron:dev\"",
    "repair:electron": "node scripts/repair-electron.js",
    "start:agent": "node src/cli.js",
    "dist:win": "npm run build:css && electron-builder --win nsis",
    "dist:mac": "npm run build:css && electron-builder --mac dmg",
    "dist:linux": "npm run build:css && electron-builder --linux AppImage"
  },
  "build": {
    "appId": "com.ventysfy.printagent",
    "productName": "Ventysfy Print Agent",
    "files": [
      "src/**/*",
      "build/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "icon": "build/icon.ico",
    "directories": {
      "output": "dist"
    }
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/static": "^6.12.0",
    "@node-escpos/core": "^0.6.0",
    "@node-escpos/network-adapter": "^0.0.1",
    "@node-escpos/serialport-adapter": "^1.0.0",
    "@node-escpos/usb-adapter": "^0.3.1",
    "fastify": "^4.28.1",
    "node-thermal-printer": "^4.4.5",
    "serialport": "^13.0.0",
    "usb": "2.15.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.11",
    "concurrently": "^9.2.0",
    "daisyui": "^5.0.46",
    "electron": "^37.2.5",
    "electron-builder": "^26.0.12",
    "pkg": "^5.8.1",
    "tailwindcss": "^4.1.11"
  },
  "engines": {
    "node": ">=18"
  }
}
